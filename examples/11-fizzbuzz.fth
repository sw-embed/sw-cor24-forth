: MOD /MOD DROP ;
: FIZZ 70 EMIT 105 EMIT 122 EMIT 122 EMIT ;
: BUZZ 66 EMIT 117 EMIT 122 EMIT 122 EMIT ;
: FIZZBUZZ FIZZ BUZZ ;
: CHECK
  DUP 15 MOD 0 = IF FIZZBUZZ DROP
  ELSE DUP 3 MOD 0 = IF FIZZ DROP
  ELSE DUP 5 MOD 0 = IF BUZZ DROP
  ELSE . THEN THEN THEN ;
: RUN 1 BEGIN DUP CHECK CR 1 + DUP 21 = UNTIL ;
RUN
